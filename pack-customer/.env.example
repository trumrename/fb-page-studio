# Copy thành .env cạnh file FB-Page-Studio-Desktop-vX.Y.Z.exe

PORT=3847
APP_BASE_URL=https://qgroup.ngrok.app

# Ngrok tích hợp trong EXE: dán token một lần trên giao diện hoặc tại đây
NGROK_AUTHTOKEN=
NGROK_AUTOSTART=1

# Meta App 1
FB_APP_ID=
FB_APP_SECRET=
FB_APP_NAME=App 1
FB_REDIRECT_URI=https://qgroup.ngrok.app/auth/facebook/callback

# Meta App 2 (tuỳ chọn)
# FB_APP_ID_2=
# FB_APP_SECRET_2=
# FB_APP_NAME_2=App 2

FB_GRAPH_VERSION=v21.0
FB_SCOPES=pages_show_list,pages_manage_posts,pages_read_engagement,pages_manage_engagement,read_insights,public_profile

TOKEN_ENCRYPTION_KEY=doi-chuoi-ngau-nhien-dai-hon-32-ky-tu!!

# Auto-update chính thức
GITHUB_REPO=trumrename/fb-page-studio
UPDATE_ASSET=FB-Page-Studio-Desktop.exe

# Chrome profile đã login Facebook (cũng có thể chọn ngay trong tool)
# FB_CHROME_PROFILE=Profile 1
# FB_CHROME_USER_DATA_DIR=C:\\Users\\TenBan\\AppData\\Local\\Google\\Chrome\\User Data
