# =============================================
# FB Page Studio — SERVER TRUNG TÂM (domain riêng)
# Copy thành .env trên VPS / máy server
# Khách chỉ mở https://domain-cua-anh/app.html
# =============================================

DEPLOY_MODE=central
PORT=3847
# Nghe mọi NIC (Nginx proxy tới 127.0.0.1:3847 cũng được)
LISTEN_HOST=0.0.0.0
TRUST_PROXY_HOPS=1

# Domain HTTPS thật của anh (DNS A/CNAME trỏ VPS)
APP_BASE_URL=https://app.ten-mien-anh.com
FB_REDIRECT_URI=https://app.ten-mien-anh.com/auth/facebook/callback

# Tắt Ngrok — domain trỏ thẳng server
NGROK_AUTOSTART=0
NGROK_AUTHTOKEN=

# Meta App (whitelist đúng FB_REDIRECT_URI trên developers.facebook.com)
FB_APP_ID=
FB_APP_SECRET=
FB_APP_NAME=App 1
FB_GRAPH_VERSION=v21.0
FB_SCOPES=pages_show_list,pages_manage_posts,pages_read_engagement,pages_manage_engagement,read_insights,public_profile

# Bắt buộc chuỗi ngẫu nhiên dài (openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=

# Mã khách nhập lần đầu (tuỳ chọn nhưng khuyến nghị)
# CENTRAL_ACCESS_TOKEN=doi-ma-bi-mat-cua-anh

# Upload ảnh từ trình duyệt
ALLOW_MEDIA_UPLOAD=1
MAX_UPLOAD_MB=80

GITHUB_REPO=trumrename/fb-page-studio
