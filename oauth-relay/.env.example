# Relay trên VPS — CÓ SECRET. Không ship vào gói khách.
# Nhiều Meta App: mỗi app 1 cặp ID/SECRET (không lặp FB_APP_ID=).
PORT=8080
LISTEN_HOST=127.0.0.1
RELAY_PUBLIC_URL=https://modelswiki.top
FB_REDIRECT_URI=https://modelswiki.top/auth/facebook/callback

# EXCHANGE=1 → gói khách không cần App Secret trên EXE
RELAY_EXCHANGE=1
DEFAULT_LOCAL_PORT=3847
FB_GRAPH_VERSION=v21.0

# App 1 (Connect app=app1)
FB_APP_ID=
FB_APP_SECRET=
FB_APP_NAME=App 1

# App 2 (Connect app=app2)
# FB_APP_ID_2=
# FB_APP_SECRET_2=
# FB_APP_NAME_2=App 2

# App 3 (Connect app=app3)
# FB_APP_ID_3=
# FB_APP_SECRET_3=
# FB_APP_NAME_3=App 3

# App N: FB_APP_ID_N / FB_APP_SECRET_N / FB_APP_NAME_N  (N=2…20)
# Cùng redirect cho mọi app (Meta whitelist 1 URI trên TỪNG app):
#   https://modelswiki.top/auth/facebook/callback
