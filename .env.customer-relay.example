# =============================================
# Máy KHÁCH — EXE portable + OAuth relay
# Folder ảnh local. KHÔNG cần Ngrok.
# =============================================

PORT=3847
# UI local
APP_BASE_URL=http://127.0.0.1:3847

# Bật relay: Connect FB không qua Ngrok
OAUTH_RELAY=1
NGROK_AUTOSTART=0
NGROK_AUTHTOKEN=

# Domain relay trên VPS (cùng URI whitelist Meta)
# Đổi thành domain thật của anh
FB_REDIRECT_URI=https://oauth.ten-mien-anh.com/auth/facebook/callback

FB_APP_ID=
FB_APP_SECRET=
FB_APP_NAME=App 1
FB_GRAPH_VERSION=v21.0
FB_SCOPES=pages_show_list,pages_manage_posts,pages_read_engagement,pages_manage_engagement,read_insights,public_profile

TOKEN_ENCRYPTION_KEY=doi-chuoi-ngau-nhien-dai-hon-32-ky-tu!!

GITHUB_REPO=trumrename/fb-page-studio
