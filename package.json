{
  "name": "fb-page-studio",
  "version": "1.2.15",
  "description": "FB Page Studio — Multi Meta App · Rotation so-le · License keys · Graph API",
  "author": "trumrename",
  "type": "module",
  "main": "electron/main.cjs",
  "githubRepo": "trumrename/fb-page-studio",
  "updateAsset": "FB-Page-Studio-Desktop.exe",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "desktop": "cross-env OPEN_BROWSER=0 electron .",
    "desktop:dev": "cross-env OPEN_BROWSER=0 electron .",
    "stop": "node scripts/stop-port.js",
    "restart": "node scripts/stop-port.js && node src/server.js",
    "init-db": "node src/db/init.js",
    "build:exe": "node scripts/build-exe.mjs",
    "release:zip": "node scripts/build-exe.mjs --zip",
    "build:desktop": "npm run native:electron && electron-builder --config.npmRebuild=false --win portable --x64",
    "build:desktop:setup": "npm run native:electron && electron-builder --config.npmRebuild=false --win nsis portable --x64",
    "pack:customer": "node scripts/sync-customer-pack.mjs",
    "build:customer": "npm run native:electron && electron-builder --config.npmRebuild=false --win portable --x64 && node scripts/sync-customer-pack.mjs",
    "release:asset": "node scripts/prepare-release-asset.mjs",
    "release:verify": "node scripts/verify-release.mjs",
    "release:strict": "npm test && npm run build:desktop && npm run pack:customer && npm run release:asset && npm run release:verify",
    "native:node": "npm rebuild better-sqlite3",
    "native:electron": "electron-rebuild -f -w better-sqlite3",
    "test": "npm run native:node && node scripts/test-requirements.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "nanoid": "^5.1.0"
  },
  "devDependencies": {
    "caxa": "^3.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
